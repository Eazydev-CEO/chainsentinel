# ============================================================================
# ChainSentinel — environment template
# Copy to .env and fill in values. NEVER commit a real .env file.
# All secrets live here — nothing is hardcoded in the codebase.
# ============================================================================

# ---------------------------------------------------------------------------
# Core Django
# ---------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.development
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me-generate-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Public origin of the frontend (links in emails, CORS, CSRF trust)
FRONTEND_URL=http://localhost:3026
BACKEND_URL=http://localhost:8212
# Comma-separated extra CSRF trusted origins (prod: https://yourdomain.com)
CSRF_TRUSTED_ORIGINS=http://localhost:3026,http://localhost:8212

# ---------------------------------------------------------------------------
# Database (PostgreSQL) — used by docker-compose and Django
# ---------------------------------------------------------------------------
POSTGRES_DB=chainsentinel
POSTGRES_USER=chainsentinel
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis — cache, Celery broker/results, locks, throttling
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------------------------------------------------------------------------
# Email (SMTP) — required for verification, resets, alert emails
# Console backend is used automatically when DJANGO_DEBUG=true and SMTP_HOST is empty.
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
DEFAULT_FROM_EMAIL=ChainSentinel <no-reply@chainsentinel.local>
# Comma-separated platform operator emails for outage/system notices
PLATFORM_ALERT_EMAILS=

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Fernet key for encrypting webhook secrets at rest.
# Leave EMPTY in development (a key is derived from DJANGO_SECRET_KEY).
# REQUIRED in production — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WEBHOOK_ENCRYPTION_KEY=
# Access/refresh token lifetimes
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=14
# Set true only behind HTTPS (production)
SECURE_COOKIES=false
# Ports outbound webhooks may target (comma separated)
WEBHOOK_ALLOWED_PORTS=80,443,8000,8080,8443

# ---------------------------------------------------------------------------
# Monitoring engine
# ---------------------------------------------------------------------------
# Max blocks processed per poll tick per chain
ENGINE_MAX_BLOCKS_PER_POLL=10
# Seconds between poll scheduling ticks
ENGINE_POLL_INTERVAL_SECONDS=10
# Optional WebSocket newHeads trigger (accelerator only; polling remains primary)
WS_SUBSCRIPTIONS_ENABLED=false
# Data retention (days)
RETENTION_EVENTS_DAYS=90
RETENTION_WEBHOOK_DELIVERIES_DAYS=30
RETENTION_HEALTH_LOGS_DAYS=14
RETENTION_WORKER_LOGS_DAYS=14

# ---------------------------------------------------------------------------
# RPC endpoints — TESTNETS for local development. Placeholders by default.
# Sign up with a provider (Alchemy/Infura/Ankr/public endpoints) and paste
# HTTPS URLs here. Leave blank to keep the provider seeded but inactive.
# NEVER put mainnet keys here unless you explicitly intend to monitor mainnet.
# ---------------------------------------------------------------------------
RPC_ETHEREUM_SEPOLIA_HTTP=
RPC_ETHEREUM_SEPOLIA_WS=
RPC_BSC_TESTNET_HTTP=
RPC_BSC_TESTNET_WS=
RPC_POLYGON_AMOY_HTTP=
RPC_POLYGON_AMOY_WS=
RPC_BASE_SEPOLIA_HTTP=
RPC_BASE_SEPOLIA_WS=
RPC_ARBITRUM_SEPOLIA_HTTP=
RPC_ARBITRUM_SEPOLIA_WS=
RPC_OPTIMISM_SEPOLIA_HTTP=
RPC_OPTIMISM_SEPOLIA_WS=

# Mainnet endpoints (chains are seeded INACTIVE; enable deliberately in admin)
RPC_ETHEREUM_HTTP=
RPC_BSC_HTTP=
RPC_POLYGON_HTTP=
RPC_BASE_HTTP=
RPC_ARBITRUM_HTTP=
RPC_OPTIMISM_HTTP=

# ---------------------------------------------------------------------------
# Frontend (Next.js)
# ---------------------------------------------------------------------------
# Base URL the browser uses for API calls ("" = same-origin via rewrites/nginx)
NEXT_PUBLIC_API_BASE_URL=
# Server-side URL Next.js uses to reach Django inside docker
API_INTERNAL_URL=http://backend:8212

# ---------------------------------------------------------------------------
# Seed data (development only — seed_dev refuses to run when DEBUG=false)
# ---------------------------------------------------------------------------
SEED_DEMO_PASSWORD=DemoPass123!
